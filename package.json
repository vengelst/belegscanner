    "next": "^15.0.0",
    "next-auth": "5.0.0-beta.22",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.10.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^6.0.1",
    "zod": "^3.24.1"
  },
