# ==============================================================================
# BelegBox - Umgebungsvariablen
# ==============================================================================
# Kopiere diese Datei nach .env und passe die Werte an.
# Geheimnisse (SECRET, KEY, PASSWORD) muessen in Produktion sicher generiert werden.
# ==============================================================================

# --- Datenbank (Pflicht) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/belegbox"

# --- Authentifizierung (Pflicht) ---
# Geheimnis fuer JWT-Signierung. Generieren: openssl rand -base64 48
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-48"
# Basis-URL der App (muss zum Deployment passen)
AUTH_URL="http://localhost:3000"

# --- Datei-Storage (Pflicht) ---
# Relativer oder absoluter Pfad zum Storage-Verzeichnis
STORAGE_PATH="./storage"

# --- ChatGPT-Beleganalyse (Pflicht) ---
# OPENAI_API_KEY="sk-..."
# Modell (optional, Default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"

# --- SMTP-Passwort-Verschluesselung (Pflicht) ---
# 32-Byte Hex-String (64 Zeichen). Generieren: openssl rand -hex 32
SMTP_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# --- Initialer Admin-Benutzer (Pflicht fuer Seed) ---
ADMIN_EMAIL="admin@belegbox.local"
ADMIN_PASSWORD="admin1234"
ADMIN_NAME="Administrator"

# --- Demo-Benutzer (Optional, nur fuer prisma:seed:demo) ---
DEMO_USER_EMAIL="demo@belegbox.local"
DEMO_USER_PASSWORD="demo1234"
DEMO_USER_NAME="Demo Benutzer"
DEMO_USER_PIN="1234"

# --- Wechselkurs-API (Optional, fuer spaetere Anbindung) ---
EXCHANGE_RATE_API_URL="https://api.frankfurter.app"
